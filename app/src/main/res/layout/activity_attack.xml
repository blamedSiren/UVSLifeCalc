<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/attack"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background_main"
    tools:context=".Attack">

    <!-- Vertical: left half | right half -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/vertical_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- Horizontal bands -->
    <!-- h1 ~15%: bottom of health labels + numbers + +/- buttons -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.20" />

    <!-- h2 ~42%: bottom of speed row -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.42" />

    <!-- h3 ~64%: bottom of damage row -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.64" />

    <!-- h4 ~85%: bottom of block buttons -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.85" />

    <!-- Vertical guideline splitting left column: big button | up/down arrows -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.35" />

    <!-- ═══════════════════════════════════
         TOP: MY HEALTH (left) + OPP HEALTH (right)
         ═══════════════════════════════════ -->

    <TextView
        android:id="@+id/my_health_label"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:fontFamily="@font/lobster"
        android:gravity="center"
        android:text="My Health"
        android:textColor="#EC8AFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/vertical_guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/my_health_3" />

    <TextView
        android:id="@+id/my_health_3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:fontFamily="@font/lobster"
        android:gravity="center"
        android:text="21"
        android:textColor="#EC8AFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/vertical_guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/my_health_label"
        app:layout_constraintBottom_toTopOf="@+id/m_m" />

    <Button
        android:id="@+id/m_m"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#EC8AFF"
        android:text="-"
        android:textColor="#70E8DE"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/m_p"
        app:layout_constraintTop_toBottomOf="@+id/my_health_3"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h1" />

    <Button
        android:id="@+id/m_p"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#EC8AFF"
        android:text="+"
        android:textColor="#70E8DE"
        app:layout_constraintStart_toEndOf="@+id/m_m"
        app:layout_constraintEnd_toStartOf="@+id/vertical_guideline"
        app:layout_constraintTop_toBottomOf="@+id/my_health_3"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h1" />

    <TextView
        android:id="@+id/opp_health_label"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="4dp"
        android:fontFamily="@font/lobster"
        android:gravity="center"
        android:text="Opponent's Health"
        android:textColor="#EC8AFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/vertical_guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/opp_health_3" />

    <TextView
        android:id="@+id/opp_health_3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="4dp"
        android:fontFamily="@font/lobster"
        android:gravity="center"
        android:text="25"
        android:textColor="#EC8AFF"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/vertical_guideline"
        app:layout_constraintTop_toBottomOf="@+id/opp_health_label"
        app:layout_constraintBottom_toTopOf="@+id/o_m" />

    <Button
        android:id="@+id/o_m"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#EC8AFF"
        android:text="-"
        android:textColor="#70E8DE"
        app:layout_constraintStart_toEndOf="@+id/vertical_guideline"
        app:layout_constraintEnd_toStartOf="@+id/o_p"
        app:layout_constraintTop_toBottomOf="@+id/opp_health_3"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h1" />

    <Button
        android:id="@+id/o_p"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#EC8AFF"
        android:text="+"
        android:textColor="#70E8DE"
        app:layout_constraintStart_toEndOf="@+id/o_m"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/opp_health_3"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h1" />

    <!-- ═══════════════════════════════════
         SPEED ROW
         ═══════════════════════════════════ -->

    <Button
        android:id="@+id/speed_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#FF5722"
        android:fontFamily="@font/lobster"
        android:text="4"
        android:textColor="#70E8DE"
        android:textSize="64sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline_v_left"
        app:layout_constraintTop_toTopOf="@+id/guideline_h1"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h2" />

    <Button
        android:id="@+id/attack_speed_up"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:backgroundTint="#EC8AFF"
        android:text="↑"
        android:textAlignment="center"
        android:textColor="#70E8DE"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="@+id/guideline_v_left"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline_h1"
        app:layout_constraintBottom_toTopOf="@+id/attack_speed_down" />

    <Button
        android:id="@+id/attack_speed_down"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#EC8AFF"
        android:text="↓"
        android:textAlignment="center"
        android:textColor="#70E8DE"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="@+id/guideline_v_left"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/attack_speed_up"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h2" />

    <!-- ═══════════════════════════════════
         DAMAGE ROW
         ═══════════════════════════════════ -->

    <Button
        android:id="@+id/attack_damage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#70E8DE"
        android:fontFamily="@font/lobster"
        android:text="4"
        android:textColor="#F69EFF"
        android:textSize="64sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline_v_left"
        app:layout_constraintTop_toTopOf="@+id/guideline_h2"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h3" />

    <Button
        android:id="@+id/attack_damage_up"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:backgroundTint="#70E8DE"
        android:text="↑"
        android:textAlignment="center"
        android:textColor="#EC8AFF"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="@+id/guideline_v_left"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline_h2"
        app:layout_constraintBottom_toTopOf="@+id/attack_damage_down" />

    <Button
        android:id="@+id/attack_damage_down"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#70E8DE"
        android:text="↓"
        android:textAlignment="center"
        android:textColor="#EC8AFF"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="@+id/guideline_v_left"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/attack_damage_up"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h3" />

    <!-- ═══════════════════════════════════
         BLOCK BUTTONS (3 equal columns)
         ═══════════════════════════════════ -->

    <!-- Vertical guidelines to split into 3 equal columns -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_block1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.345" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v_block2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.655" />

    <Button
        android:id="@+id/full_block_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#70E8DE"
        android:fontFamily="@font/lobster"
        android:text="Full Block"
        android:textColor="#EC8AFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h4"
        app:layout_constraintEnd_toStartOf="@+id/guideline_v_block1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline_h3" />

    <Button
        android:id="@+id/half_block_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#70E8DE"
        android:fontFamily="@font/lobster"
        android:text="Half Block"
        android:textColor="#EC8AFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h4"
        app:layout_constraintEnd_toStartOf="@+id/guideline_v_block2"
        app:layout_constraintStart_toStartOf="@+id/guideline_v_block1"
        app:layout_constraintTop_toTopOf="@+id/guideline_h3" />

    <Button
        android:id="@+id/unblocked_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#70E8DE"
        android:fontFamily="@font/lobster"
        android:text="Unblocked"
        android:textColor="#EC8AFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline_v_block2"
        app:layout_constraintTop_toTopOf="@+id/guideline_h3" />

</androidx.constraintlayout.widget.ConstraintLayout>